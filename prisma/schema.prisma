// Multi-tenant rezervační jádro hotelového systému.
//
// Centrální systém eviduje N provozoven (Property) tří typů — hotel / penzion
// / ubytovna — které se chovají různě (jednotka inventáře, pobytový poplatek,
// dlouhodobé pobyty, self check-in). Vše je scopované přes propertyId.
// Uživatelé mají role a přiřazení k provozovnám.
//
// Provider: PostgreSQL (enumy + pole).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enumy
// ─────────────────────────────────────────────────────────────

enum PropertyType {
  hotel
  penzion
  ubytovna
}

/// Jednotka inventáře: celý pokoj (hotel/penzion) vs. lůžko ve sdíleném pokoji (ubytovna).
enum InventoryUnit {
  room
  bed
}

enum UserRole {
  super_admin  // vidí a spravuje vše napříč provozovnami
  manager      // jen přiřazené provozovny
  housekeeping // uklízečka — fronta úklidu/služeb
  maintenance  // údržbář — fronta údržby
}

enum ServiceType {
  cleaning // úklid
  maintenance // údržba
  laundry // praní
  ironing // žehlení
  minibar // doplnění minibaru
  other // jiné
}

/// Komu požadavek patří do fronty.
enum ServiceDomain {
  housekeeping
  maintenance
}

enum ServiceStatus {
  open
  in_progress
  done
  cancelled
}

enum BillingCycle {
  per_stay // platba za celý pobyt (hotel/penzion)
  monthly  // měsíční fakturace (ubytovna, dlouhodobé)
}

enum RoomStatus {
  clean
  dirty
  to_inspect // ke kontrole / dennímu úklidu (obsazený pokoj bez dnešního odjezdu)
  inspected // uklizeno a zkontrolováno
  out_of_service
}

enum LockType {
  physical_key
  smart_code
}

enum ReservationStatus {
  pending
  hold
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

enum ReservationSource {
  kiosk
  kiosk_walkin
  booking_com
  manual
  ical
  group
}

/// Platební režim skupiny: kolektivně (jeden plátce/společná faktura) nebo individuálně (každý pokoj sám).
enum GroupBilling {
  collective
  individual
}

enum PaymentType {
  deposit
  balance
  city_tax
  extra
  deposit_hold
  refund
}

enum PaymentMethod {
  card_terminal
  prepaid
  cash
  invoice // fakturou (firmy, ubytovny)
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum DocumentType {
  id_card
  passport
}

enum EquipmentCondition {
  ok
  damaged
  retired
}

enum BillingDocType {
  proforma // zálohová faktura (výzva k platbě, ne daňový doklad)
  advance_tax // daňový doklad k přijaté záloze (plátce DPH)
  invoice // konečná faktura / daňový doklad
  receipt // účtenka / zjednodušený daňový doklad / doklad o zaplacení
  credit_note // opravný daňový doklad (dobropis)
}

enum DocumentStatus {
  draft
  issued
  paid
  cancelled
}

enum CashMovementKind {
  income // příjem (PPD)
  expense // výdej (VPD)
}

/// Kategorie připsané položky na účet pokoje (mimo ubytování + poplatek, ty jsou na rezervaci).
enum ChargeCategory {
  minibar
  laundry // praní
  ironing // žehlení
  wellness
  service // služby (úklid navíc, pronájem…)
  restaurant // restaurace / bar
  parking
  discount // sleva (záporná položka — např. dorovnání ceny při přesunu pokoje)
  other
}

// ─────────────────────────────────────────────────────────────
// Centrální systém: provozovny a uživatelé
// ─────────────────────────────────────────────────────────────

/// Provozovna (hotel / penzion / ubytovna). Kořen multi-tenance.
model Property {
  id         String       @id @default(uuid())
  identifier String       @unique // např. "HOTEL-PRAHA-01" — pod tímto kódem běží recepce/kiosek
  name       String
  type       PropertyType

  street  String?
  city    String?
  country String? @default("CZ")
  phone   String?
  email   String?
  ico      String? // IČO provozovny (dodavatel na dokladech)
  dic      String? // DIČ provozovny
  iban     String? // bankovní účet (IBAN) pro QR platbu na proformě
  vatPayer Boolean @default(false) // plátce DPH — určuje typy a náležitosti dokladů

  // Provozovatel = firma, která fakturuje (dodavatel na dokladech). Když je vyplněn, má přednost před údaji provozovny.
  operatorName         String? // název firmy provozovatele
  operatorAddress      String? // sídlo (ulice, město, PSČ)
  operatorRegistration String? // dodatek — zápis v rejstříku (např. „Zapsána u Městského soudu v Praze, oddíl C, vložka 12345")
  operatorAccount      String? // číslo účtu (zobrazené na dokladech)
  operatorIco          String? // IČO provozovatele
  operatorDic          String? // DIČ provozovatele
  active   Boolean @default(true)
  infoText String? // volný text pro AI asistenta (FAQ, služby, pravidla)

  // Typově závislé chování (výchozí dle typu, ale přepsatelné per provozovna).
  inventoryUnit         InventoryUnit @default(room)
  cityTaxEnabled        Boolean       @default(true)  // hotel/penzion ano, ubytovna typicky ne
  cityTaxPerPersonNight Decimal       @default(50) @db.Decimal(10, 2)
  cityTaxFreeAge        Int           @default(18) // děti do tohoto věku pobytový poplatek neplatí
  allowLongTerm         Boolean       @default(false) // ubytovna: pobyty na týdny/měsíce
  selfCheckin           Boolean       @default(false) // ubytovna: plně samoobslužné
  breakfastIncluded     Boolean       @default(false)
  dailyCleaning         Boolean       @default(false) // hotel: denní úklid → obsazené pokoje bez odjezdu se ráno označí „Zkontrolovat"
  offeredServices       String[]      @default(["cleaning", "laundry", "ironing", "minibar"]) // služby nabízené hostům v portálu (ServiceType)

  // Texty zobrazené na kiosku po ubytování (výsledková obrazovka). Volné, per provozovna.
  kioskKeyInfo String? // instrukce k vyzvednutí klíče (např. „Klíč je pod monitorem")
  kioskWifi    String? // Wi-Fi údaj (např. „PenzionWifi / vitejte")

  energyFeePerNight Decimal @default(0) @db.Decimal(10, 2) // „vzdušné" — energetický poplatek za lůžko/noc (firemní ubytovny)
  onlineCheckinHours    Int           @default(48) // okno online check-inu v portálu hosta (h před příjezdem); jen když selfCheckin

  // Storno / zálohové politiky + automatika (0 = vypnuto).
  freeCancelDays Int @default(0) // bezplatné storno do N dní před příjezdem; po lhůtě storno poplatek
  cancelFeePct   Int @default(0) // storno poplatek v % z ceny při pozdním zrušení
  depositPct     Int @default(0) // požadovaná záloha v % z ceny (informativně v potvrzení)
  reminderHours  Int @default(0) // připomínka hostovi H hodin před příjezdem
  noShowHours    Int @default(0) // po G hodinách od data příjezdu označit nedoraženého jako no-show

  rooms        Room[]
  beds         Bed[]
  roomTypes    RoomType[]
  reservations Reservation[]
  users        UserProperty[]
  equipment    EquipmentItem[]
  serviceRequests ServiceRequest[]
  documents     Document[]
  cashRegisters CashRegister[]
  serviceItems  ServiceItem[]
  icalFeeds     IcalFeed[]
  reviews       GuestReview[]
  reservationGroups ReservationGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Uživatel centrálního systému.
model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String
  passwordHash String
  role         UserRole       @default(manager)
  active       Boolean        @default(true)
  properties   UserProperty[] // přiřazené provozovny (manager/personál); super_admin vidí vše

  resolvedRequests ServiceRequest[] @relation("ResolvedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Přiřazení uživatele (manager) k provozovně (M:N).
model UserProperty {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  @@unique([userId, propertyId])
}

// ─────────────────────────────────────────────────────────────
// Inventář (scopovaný na provozovnu)
// ─────────────────────────────────────────────────────────────

/// Typ pokoje / lůžka. Cena se interpretuje za jednotku (pokoj nebo lůžko).
model RoomType {
  id         String   @id @default(uuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  name             String
  description      String?
  capacityAdults   Int
  capacityChildren Int      @default(0)
  maxExtraBeds     Int      @default(0) // kolik přistýlek lze do pokoje přidat (0 = nelze)
  extraBedPrice    Decimal  @default(0) @db.Decimal(10, 2) // cena za přistýlku a noc
  basePrice        Decimal  @db.Decimal(10, 2) // za jednotku a noc
  weeklyPrice      Decimal? @db.Decimal(10, 2) // dlouhodobé (ubytovna)
  monthlyPrice     Decimal? @db.Decimal(10, 2)
  amenities        String[]
  photos           String[]

  rooms        Room[]
  reservations Reservation[]
  ratePlans    RatePlan[]
  icalFeeds    IcalFeed[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
}

/// Fyzický pokoj. U ubytovny je to sdílený pokoj obsahující lůžka (Bed).
model Room {
  id         String   @id @default(uuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  roomTypeId String

  number   String
  floor    Int
  status   RoomStatus @default(clean)
  lockType LockType   @default(physical_key)
  notes    String?
  dailyServiceDate DateTime? @db.Date // den, kdy byl naposledy automaticky označen „Zkontrolovat" (dedup denní automatiky)

  beds         Bed[]
  reservations Reservation[]
  equipment    EquipmentItem[]
  serviceRequests ServiceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, number])
  @@index([propertyId])
}

/// Lůžko ve sdíleném pokoji (jen ubytovna, inventoryUnit = bed).
model Bed {
  id         String   @id @default(uuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId     String
  label      String // např. "204-A"
  status     RoomStatus @default(clean)

  reservations Reservation[]
  occupancies  BedOccupancy[]

  createdAt DateTime @default(now())

  @@unique([propertyId, label])
  @@index([roomId])
}

// ─────────────────────────────────────────────────────────────
// Hosté a rezervace
// ─────────────────────────────────────────────────────────────

/// Host — globální (může bydlet ve více provozovnách).
model Guest {
  id        String  @id @default(uuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  language  String?

  // Doklad totožnosti a adresa (pro evidenci ubytovaných osob + UBYPORT).
  // Nepovinné v adresáři; když je klient poskytne, evidenční kniha/UBYPORT se z nich vyplní samy.
  address        String?
  documentType   DocumentType?
  documentNumber String?
  dateOfBirth    DateTime?     @db.Date
  nationality    String?

  marketingConsent Boolean @default(false)

  // CRM — trvalé preference napříč pobyty (alergie, preference pokoje/lůžka…) a VIP příznak.
  preferences String?
  vip         Boolean @default(false)

  reservationsAsPrimary Reservation[]       @relation("PrimaryGuest")
  reservationGuests     ReservationGuest[]
  registrationEntries   RegistrationEntry[]
  reviews               GuestReview[]
  organizedGroups       ReservationGroup[]
  bedOccupancies        BedOccupancy[]      @relation("OccupantBed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

/// Hodnocení pobytu hostem (NPS 0–10 + komentář). Jedno na rezervaci.
model GuestReview {
  id            String      @id @default(uuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String      @unique
  property      Property    @relation(fields: [propertyId], references: [id])
  propertyId    String
  guest         Guest       @relation(fields: [guestId], references: [id])
  guestId       String
  nps           Int // 0–10 (jak pravděpodobně by nás doporučil)
  comment       String?
  createdAt     DateTime    @default(now())

  @@index([propertyId, createdAt])
}

enum OccupancyStatus {
  active // probíhá / naplánováno (zatím neukončeno)
  ended  // ukončeno (pracovník odešel / vystřídán)
}

// Číselník typů osob s cenou za noc (děti dle věku, senior, uprchlík…). Volně přidatelný, per provozovna.
model PersonRate {
  id            String  @id @default(uuid())
  propertyId    String
  name          String // např. „Dítě do 10 let", „Senior nad 65", „Uprchlík"
  ageFrom       Int? // věk od (včetně); null = bez spodní hranice
  ageTo         Int? // věk do (včetně); null = bez horní hranice
  pricePerNight Decimal @default(0) @db.Decimal(10, 2)
  sortOrder     Int     @default(0)
  active        Boolean @default(true)

  occupancies       BedOccupancy[]
  reservations      Reservation[]
  reservationGuests ReservationGuest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, active])
}

/// Ceník sjednaných sazeb za lůžko/noc (firemní ubytovny) — per provozovna. = TVM PriceList.
model BedRate {
  id            String  @id @default(uuid())
  propertyId    String
  name          String // např. „Standard", „Agentura X", „Dvoulůžko"
  pricePerNight Decimal @default(0) @db.Decimal(10, 2)
  sortOrder     Int     @default(0)
  active        Boolean @default(true)

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, active])
}

enum DepositStatus {
  held      // kauce přijata a držena
  returned  // vrácena hostovi (celá nebo částečně)
  forfeited // zadržena (propadla — škoda apod.)
}

// Vratná kauce (jistota). Drží se a později vrací / zadrží. Odděleně od plateb a účtu.
model Deposit {
  id         String @id @default(uuid())
  propertyId String

  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  reservationId String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId     String?

  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod @default(cash)
  status         DepositStatus @default(held)
  takenAt        DateTime      @default(now())
  returnedAt     DateTime?
  returnedAmount Decimal?      @db.Decimal(10, 2) // kolik reálně vráceno (při částečném zadržení < amount)
  note           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, status])
  @@index([reservationId])
  @@index([companyId])
}

// Obsazení lůžka konkrétní osobou v daném období (firemní ubytovny). Osoby se na lůžku střídají
// nezávisle na rezervaci — tohle je „kdo reálně spí v lůžku od–do".
model BedOccupancy {
  id         String @id @default(uuid())
  propertyId String // denormalizováno pro scoping (lůžko nese FK na provozovnu)

  bed   Bed    @relation(fields: [bedId], references: [id], onDelete: Cascade)
  bedId String

  occupant        Guest  @relation("OccupantBed", fields: [occupantGuestId], references: [id])
  occupantGuestId String

  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId String?

  // Obsazení je vždy POD rezervací lůžka (TVM Occupation pod Booking/BookedBed) — rotace osob.
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String

  personRate   PersonRate? @relation(fields: [personRateId], references: [id], onDelete: SetNull)
  personRateId String?
  dateOfBirth  DateTime?   @db.Date // datum narození osoby — pro automatický výběr cenové kategorie dle věku

  fromDate     DateTime        @db.Date
  toDate       DateTime        @db.Date
  status       OccupancyStatus @default(active)
  pricePerNight Decimal        @default(0) @db.Decimal(10, 2) // cena za lůžko/noc pro fakturaci firmě
  energyFeeExempt Boolean      @default(false) // osvobozeno od energetického poplatku („vzdušné")
  invoicedAt   DateTime? // kdy byla obsazenost zahrnuta do faktury firmě (zamezí dvojí fakturaci)
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, status])
  @@index([bedId, fromDate, toDate])
  @@index([companyId])
}

// Firma / odběratel (centrální adresář, sdílený napříč provozovnami) — pro firemní ubytovny i služební pobyty.
model Company {
  id      String  @id @default(uuid())
  name    String
  ico     String? // IČO
  dic     String? // DIČ
  account String? // číslo účtu
  street  String?
  city    String?
  zip     String?
  country String? @default("CZ")
  email    String?
  phone    String?
  note     String?
  vatPayer Boolean @default(false) // plátce DPH (ověřeno přes VIES / dle DIČ)
  active   Boolean @default(true)

  reservations Reservation[]
  occupancies  BedOccupancy[]
  deposits     Deposit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Reservation {
  id   String @id @default(uuid())
  code String @unique

  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String

  primaryGuest   Guest  @relation("PrimaryGuest", fields: [primaryGuestId], references: [id])
  primaryGuestId String

  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  roomTypeId String

  // Přiřazená jednotka: pokoj (hotel/penzion) nebo lůžko (ubytovna).
  room   Room?   @relation(fields: [roomId], references: [id])
  roomId String?
  bed    Bed?    @relation(fields: [bedId], references: [id])
  bedId  String?

  checkInDate  DateTime @db.Date
  checkOutDate DateTime @db.Date
  nights       Int
  adults       Int      @default(1)
  children     Int      @default(0)
  childAges    Int[]    @default([]) // věk jednotlivých dětí — pro výpočet osvobození od pobytového poplatku

  status       ReservationStatus @default(pending)
  source       ReservationSource @default(manual)
  billingCycle BillingCycle      @default(per_stay)

  note String? // poznámka recepce — přání a požadavky hosta

  doNotDisturb Boolean   @default(false) // „Nerušit" — host si nepřeje úklid (nastaví host/recepce/úklid)
  dndSince     DateTime? // od kdy je Nerušit aktivní

  totalAmount Decimal @default(0) @db.Decimal(10, 2)
  cityTax     Decimal @default(0) @db.Decimal(10, 2)

  // Energetický poplatek („vzdušné") — u lůžkových (firemních) pobytů se účtuje navíc, leda osvobozeno.
  energyFeeExempt Boolean @default(false)

  // Dlouhodobé/firemní ubytování (TVM Booking): sjednaná sazba, splatnost, zaplaceno do, VIP.
  bedRate    BedRate?  @relation(fields: [bedRateId], references: [id], onDelete: SetNull)
  bedRateId  String?
  payUntil   DateTime? @db.Date
  paidTo     DateTime? @db.Date
  vip        Boolean   @default(false)

  // Fakturace firmě (ubytovny / služební pobyty). Volný text = starší override; companyId = centrální firma.
  billingCompany String?
  billingIco     String?
  billingDic     String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId      String?
  personRate     PersonRate? @relation(fields: [personRateId], references: [id], onDelete: SetNull)
  personRateId   String?

  holdExpiresAt DateTime?

  onlineCheckinAt DateTime? // host dokončil online check-in (vyplnil registrační údaje); recepce finalizuje příjezd
  externalRef     String?   // blokace z externího iCal feedu: "<feedId>:<UID>" (pro dedup při synchronizaci)

  // Skupinová / vícepokojová rezervace — víc pokojů (firma, zájezd, svatba) pod jednou skupinou.
  group   ReservationGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId String?

  reservationGuests   ReservationGuest[]
  payments            Payment[]
  charges             Charge[]
  registrationEntries RegistrationEntry[]
  serviceRequests     ServiceRequest[]
  documents           DocumentReservation[]
  emailLogs           EmailLog[]
  review              GuestReview?
  bedOccupancies      BedOccupancy[]
  deposits            Deposit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, checkInDate, checkOutDate])
  @@index([propertyId, status])
  @@index([externalRef])
  @@index([groupId])
  @@index([companyId])
}

/// Skupinová rezervace — blok více pokojů/jednotek pod jedním kontaktem
/// (firma, zájezd, svatba). Každý pokoj je samostatná Reservation se svým
/// check-inem a účtem; skupina je spojuje pro společný přehled a akce.
model ReservationGroup {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String
  note       String?

  // Platební režim: kolektivně (jeden plátce / společná faktura) nebo individuálně (každý pokoj má vlastní účet).
  billing    GroupBilling @default(individual)

  // Kontakt skupiny (organizátor) — pro souhrnný e-mail.
  organizer       Guest?  @relation(fields: [organizerGuestId], references: [id])
  organizerGuestId String?

  reservations Reservation[]
  emailLogs    EmailLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
}

/// Externí iCal feed (Airbnb/Booking/…) — synchronizuje obsazenost do blokujících rezervací.
model IcalFeed {
  id           String    @id @default(uuid())
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId   String
  roomType     RoomType  @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  roomTypeId   String
  url          String
  label        String?
  blockGuestId String?   // sdílený „host" pro blokace z tohoto feedu
  lastSyncedAt DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())

  @@index([propertyId])
}

/// Záznam o odeslaném (nebo neúspěšném) e-mailu hostovi — pro přehled v detailu
/// rezervace a možnost znovuodeslání.
model EmailLog {
  id            String       @id @default(uuid())
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String?
  group         ReservationGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId       String?
  type          String // created | checkin | checkout | cancellation | group_summary
  recipient     String
  subject       String
  status        String // sent | failed | skipped
  error         String?
  createdAt     DateTime     @default(now())

  @@index([reservationId, createdAt])
  @@index([groupId, createdAt])
}

model ReservationGuest {
  id            String      @id @default(uuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String
  guest         Guest       @relation(fields: [guestId], references: [id])
  guestId       String
  isPrimary     Boolean     @default(false)

  // Typ osoby per ubytovaný (dítě/senior…). Určuje cenu přistýlky, na které osoba spí.
  personRate    PersonRate? @relation(fields: [personRateId], references: [id], onDelete: SetNull)
  personRateId  String?

  @@unique([reservationId, guestId])
}

model Payment {
  id            String        @id @default(uuid())
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String
  type          PaymentType
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(pending)
  description   String?
  invoiceNumber String?

  // Vazba na doklad a pokladní směnu (hotovost).
  document      Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  documentId    String?
  cashSession   CashRegisterSession? @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  cashSessionId String?

  createdAt DateTime @default(now())

  @@index([reservationId])
  @@index([documentId])
  @@index([cashSessionId])
}

/// Ceník služeb provozovny (číselník) — nabídne se cena při připsání na účet.
model ServiceItem {
  id         String         @id @default(uuid())
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  name       String
  category   ChargeCategory @default(other)
  price      Decimal        @db.Decimal(10, 2)
  vatRate    Decimal        @default(0) @db.Decimal(5, 2)
  active     Boolean        @default(true)

  createdAt DateTime @default(now())

  @@index([propertyId])
}

/// Připsaná položka na účet pokoje (konzumace/služby). Náklad k úhradě, NE platba.
model Charge {
  id            String        @id @default(uuid())
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String
  category      ChargeCategory
  description   String?
  quantity      Decimal       @default(1) @db.Decimal(10, 2)
  unitPrice     Decimal       @db.Decimal(10, 2)
  amount        Decimal       @db.Decimal(10, 2) // quantity * unitPrice (snímek)
  vatRate       Decimal       @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  @@index([reservationId])
}

model RegistrationEntry {
  id            String      @id @default(uuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String
  guest         Guest       @relation(fields: [guestId], references: [id])
  guestId       String

  fullName       String
  dateOfBirth    DateTime     @db.Date
  nationality    String
  documentType   DocumentType
  documentNumber String
  homeAddress    String
  visaNumber     String?
  purposeOfStay  String?
  stayFrom       DateTime     @db.Date
  stayTo         DateTime     @db.Date

  retentionUntil DateTime @db.Date

  createdAt DateTime @default(now())

  @@index([reservationId])
  @@index([retentionUntil])
}

model RatePlan {
  id         String   @id @default(uuid())
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  roomTypeId String
  date       DateTime @db.Date
  price      Decimal  @db.Decimal(10, 2)

  @@unique([roomTypeId, date])
}

/// Číselník kategorií vybavení (spravuje se centrálně).
model EquipmentCategory {
  id    String          @id @default(uuid())
  name  String          @unique
  items EquipmentItem[]
}

/// Kus vybavení (evidence DHIM). Umístění:
///   propertyId=null, roomId=null  → centrální sklad
///   propertyId=X,    roomId=null  → sklad provozovny X
///   propertyId=X,    roomId=R     → pokoj R v provozovně X
model EquipmentItem {
  id           String             @id @default(uuid())
  name         String
  code         String?            @unique // jedinečný kód pro čtečku (čárový/QR)
  serialNumber String?
  condition    EquipmentCondition @default(ok)
  note         String?

  category   EquipmentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId String?

  acquiredAt     DateTime? @db.Date // datum pořízení
  manufacturedAt DateTime? @db.Date // datum výroby
  retiredAt      DateTime? @db.Date // datum vyřazení
  retiredReason  String? // důvod vyřazení

  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId String?
  room       Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  roomId     String?

  moves EquipmentMove[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([roomId])
  @@index([categoryId])
}

/// Servisní požadavek (tiket) — od hosta i personálu.
model ServiceRequest {
  id         String   @id @default(uuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String

  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  reservationId String?
  room          Room?        @relation(fields: [roomId], references: [id], onDelete: SetNull)
  roomId        String?
  bedId         String?

  type        ServiceType
  domain      ServiceDomain
  status      ServiceStatus @default(open)
  description String?
  fromGuest   Boolean       @default(false) // zadal host (vs. personál)
  imageUrls   String[]      @default([]) // fotky závady (z telefonu personálu)

  note         String? // poznámka personálu při řešení
  resolvedBy   User?     @relation("ResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedById String?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, domain, status])
  @@index([reservationId])
}

/// Historie přesunů (evidence). Lokace ukládáme jako čitelný text snapshot,
/// ať záznam přežije i smazání pokoje/provozovny.
model EquipmentMove {
  id        String        @id @default(uuid())
  item      EquipmentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  fromLabel String
  toLabel   String
  note      String?
  createdAt DateTime      @default(now())

  @@index([itemId])
}

// ─────────────────────────────────────────────────────────────
// Doklady (faktury, zálohy, účtenky) a pokladna
// ─────────────────────────────────────────────────────────────

/// Vystavený doklad. Dodavatel i odběratel jsou SNÍMEK k datu vystavení
/// (doklad je neměnný i po změně údajů provozovny/hosta).
model Document {
  id         String         @id @default(uuid())
  property   Property       @relation(fields: [propertyId], references: [id])
  propertyId String
  type       BillingDocType
  number     String         @unique // číselná řada per typ a rok (FA-2026-0001…)
  status     DocumentStatus @default(issued)

  issuedAt DateTime  @default(now())
  taxDate  DateTime? @db.Date // DUZP — datum uskutečnění zdanitelného plnění
  dueDate  DateTime? @db.Date // splatnost (proforma / faktura)

  // Snímek dodavatele (provozovatel v čase vystavení).
  supplierName         String
  supplierAddress      String?
  supplierIco          String?
  supplierDic          String?
  supplierRegistration String? // dodatek — zápis v rejstříku
  supplierAccount      String? // číslo účtu na dokladu
  vatPayer             Boolean @default(false) // vystaveno jako plátce DPH?

  // Odběratel (host nebo firma).
  customerName    String
  customerAddress String?
  customerIco     String?
  customerDic     String?

  subtotal  Decimal @default(0) @db.Decimal(10, 2) // základ (bez DPH, nebo celek u neplátce)
  vatTotal  Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @default(0) @db.Decimal(10, 2)
  paidTotal Decimal @default(0) @db.Decimal(10, 2)

  note String?

  lines        DocumentLine[]
  payments     Payment[]
  reservations DocumentReservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId, type, issuedAt])
  @@index([propertyId, status])
}

model DocumentLine {
  id         String   @id @default(uuid())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  label     String
  qty       Decimal @default(1) @db.Decimal(10, 2)
  unitPrice Decimal @db.Decimal(10, 2) // jednotková cena (vč. DPH u neplátce / koncová)
  vatRate   Decimal @default(0) @db.Decimal(5, 2) // 0 / 12 / 21
  lineTotal Decimal @db.Decimal(10, 2)

  @@index([documentId])
}

/// M:N doklad ↔ rezervace (hromadná faktura za víc pobytů).
model DocumentReservation {
  document      Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId    String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  reservationId String

  @@id([documentId, reservationId])
  @@index([reservationId])
}

/// Atomický čítač číselných řad. key = "<typ>-<rok>" nebo "<prefix>-<rok>".
model DocumentCounter {
  id    String @id @default(uuid())
  key   String @unique
  value Int    @default(0)
}

/// Pokladna provozovny (může jich být víc — recepce, bar).
model CashRegister {
  id         String   @id @default(uuid())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyId String
  name       String

  sessions CashRegisterSession[]

  createdAt DateTime @default(now())

  @@index([propertyId])
}

/// Pokladní směna (od otevření po uzávěrku).
model CashRegisterSession {
  id         String       @id @default(uuid())
  register   CashRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)
  registerId String

  openedAt     DateTime @default(now())
  openedById   String // userId
  openingFloat Decimal  @default(0) @db.Decimal(10, 2) // počáteční stav hotovosti

  closedAt    DateTime?
  closedById  String?
  countedCash Decimal? @db.Decimal(10, 2) // spočítaná hotovost při uzávěrce
  note        String?

  movements CashMovement[]
  payments  Payment[]

  @@index([registerId, openedAt])
}

/// Pohyb v pokladně — příjmový (PPD) / výdajový (VPD) doklad.
model CashMovement {
  id        String              @id @default(uuid())
  session   CashRegisterSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  kind       CashMovementKind
  amount     Decimal          @db.Decimal(10, 2)
  paymentId  String? // volitelná vazba na platbu
  documentId String? // volitelná vazba na doklad
  note       String?

  createdAt DateTime @default(now())

  @@index([sessionId])
}
