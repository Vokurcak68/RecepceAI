# Zkopíruj na .env a doplň reálné hodnoty.
# Pro lokální vývoj stačí Postgres přes Docker:
#   docker run --name receptionai-db -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgres
DATABASE_URL="postgresql://postgres:dev@localhost:5432/receptionai?schema=public"

# ── Hlasový AI asistent v kiosku (Claude tool use) ───────────
ANTHROPIC_API_KEY="sk-ant-..."
AI_MODEL="claude-haiku-4-5"            # volitelné, výchozí claude-haiku-4-5

# ── WhatsApp (whatsapp-web.js, propojené zařízení) ───────────
# Slouží JEN k odeslání notifikace personálu při volání člověka z kiosku (odkaz na Jitsi).
# WHATSAPP_ENABLED=false               # úplně vypne připojení k WhatsAppu
STAFF_WHATSAPP="420724239572"         # číslo personálu pro alert při volání z kiosku (jen číslice)
# CHROME_PATH="C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe"

# ── Videohovor JaaS (8x8) — odstraní 5min limit i hlášku meet.jit.si ─────────
# Z JaaS konzole (https://jaas.8x8.vc): App ID, API Key (kid) a stažený privátní klíč.
# Když je vyplněno, /call/token podepíše JWT; jinak kiosek jede na veřejném meet.jit.si.
# JAAS_APP_ID="vpaas-magic-cookie-xxxxxxxxxxxxxxxx"
# JAAS_KID="vpaas-magic-cookie-xxxxxxxxxxxxxxxx/abc123"
# JAAS_KEY_FILE="./jaas-key.pem"        # cesta ke staženému privátnímu klíči (gitignored)
# JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----"  # alternativa k souboru
